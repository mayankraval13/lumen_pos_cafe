PORT=5173
BASE_PATH=/

# Optional: API origin when the browser cannot use the Vite proxy (same machine: usually leave unset).
# Example from a phone: VITE_API_BASE=http://192.168.1.10:3001
# VITE_API_BASE=

# Optional: override proxy target (default http://127.0.0.1:3001)
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# Set to true only if another layer already handles /api routing
# VITE_DISABLE_API_PROXY=true
